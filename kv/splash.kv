<SplashScreen>:
    name: "splash"

    FloatLayout:

        canvas.before:
            Color:
                rgba: 0.09, 0.12, 0.27, 1   # Dark Blue
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "MACHCHAT"
            font_size: "34sp"
            bold: True
            color: 1,1,1,1
            pos_hint: {"center_x": .5, "center_y": .60}

        Label:
            text: "Chat Freely"
            font_size: "18sp"
            color: .8,.8,.8,1
            pos_hint: {"center_x": .5, "center_y": .52}

        Label:
            text: "Loading..."
            font_size: "16sp"
            color: 1,1,1,1
            pos_hint: {"center_x": .5, "center_y": .20}