<LoginScreen>

MDScreen:

    MDBoxLayout:
        orientation: "vertical"
        padding: "30dp"
        spacing: "20dp"

        Widget:
            size_hint_y: .4

        MDLabel:
            text: "MACHCHAT"
            halign: "center"
            font_style: "H4"
            bold: True

        MDLabel:
            text: "Sign in to continue"
            halign: "center"
            theme_text_color: "Secondary"

        MDTextField:
            id: email
            hint_text: "Email"
            helper_text: "Enter your email"
            helper_text_mode: "on_focus"
            icon_left: "email"
            mode: "rectangle"

        MDTextField:
            id: password
            hint_text: "Password"
            password: True
            icon_left: "lock"
            mode: "rectangle"

        MDRaisedButton:
            text: "LOGIN"
            pos_hint: {"center_x": .5}
            on_release: root.login()

        MDTextButton:
            text: "Create Account"
            pos_hint: {"center_x": .5}
            on_release: root.register()

        Widget:
            size_hint_y: .5