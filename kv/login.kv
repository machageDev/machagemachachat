<LoginScreen>:
    name: "login"

    FloatLayout:

        canvas.before:
            Color:
                rgba: 1,1,1,1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Login Screen"
            font_size: "30sp"
            color: 0,0,0,1
            pos_hint: {"center_x": .5, "center_y": .5}